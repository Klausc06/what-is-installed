#!/usr/bin/env bash
set -euo pipefail

# what-is-installed — 增强版命令行工具扫描器
#
# 职责：扫描用户系统中常见的命令行工具安装位置，展示已安装的工具及其版本信息
# 设计原则：保持保守的默认策略，通过参数启用扩展功能；零外部依赖

LANGUAGE=""
SHOW_VERSION=false
SCAN_ALL=false
QUIET_MODE=false

# ============================================================================
# 扫描目录配置
# ============================================================================

# 默认扫描目录（保守策略）
DEFAULT_SCAN_DIRS=(
  "$HOME/.local/bin"
  "$HOME/.npm-global/bin"
  "/opt/homebrew/bin"
)

# 扩展扫描目录（--all 模式）
EXTENDED_SCAN_DIRS=(
  "$HOME/.cargo/bin"           # Rust / Cargo
  "$HOME/go/bin"               # Go
  "$HOME/.local/pipx/venvs"    # pipx (需要特殊处理)
  "$HOME/.local/bin/pipx"      # pipx 替代位置
  "$HOME/miniconda3/bin"       # Miniconda
  "$HOME/anaconda3/bin"        # Anaconda
  "$HOME/.local/share/mise/shims"  # mise
  "$HOME/.asdf/shims"          # asdf
  "/home/linuxbrew/.linuxbrew/bin" # Linux Homebrew
  "$HOME/Library/pnpm"         # pnpm
  "/usr/local/bin"             # 传统 Unix
  "/usr/local/sbin"
)

# ============================================================================
# 命令参数解析
# ============================================================================

usage() {
  cat <<'EOF'
Usage: what-is-installed [OPTIONS]

Options:
  --lang zh|en   Output language. Supported: zh, en
  --version      Show version info for discovered commands
  --all          Scan extended directories (cargo, go, pipx, conda, etc.)
  --quiet        Only show scan results, no notes/comments
  --help, -h     Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --lang)
      [[ $# -ge 2 ]] || { printf '%s\n' "Missing value for --lang" >&2; exit 1; }
      LANGUAGE="$2"
      shift 2
      ;;
    --version)
      SHOW_VERSION=true
      shift
      ;;
    --all)
      SCAN_ALL=true
      shift
      ;;
    --quiet)
      QUIET_MODE=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# ============================================================================
# 语言/国际化
# ============================================================================

resolve_lang() {
  if [[ -n "$LANGUAGE" ]]; then
    printf '%s\n' "$LANGUAGE"
    return
  fi

  case "${LC_ALL:-${LANG:-}}" in
    zh*|ZH*)
      printf '%s\n' "zh"
      ;;
    *)
      printf '%s\n' "en"
      ;;
  esac
}

LANGUAGE="$(resolve_lang)"

t() {
  local key="$1"
  case "$LANGUAGE:$key" in
    zh:usage_missing_lang) printf '%s\n' "缺少 --lang 的取值" ;;
    zh:summary) printf '%s\n' "概览" ;;
    zh:local_bin) printf '%s\n' "用户命令目录" ;;
    zh:npm_bin) printf '%s\n' "npm 全局目录" ;;
    zh:homebrew_bin) printf '%s\n' "Homebrew 目录" ;;
    zh:summary_note) printf '%s\n' "说明: 这三处通常分别对应用户级命令、npm 全局命令和 Homebrew 命令。" ;;
    zh:found_commands) printf '%s\n' "已发现的命令" ;;
    zh:found_commands_note) printf '%s\n' "说明: 这里只展示在常见安装目录里实际搜索到的可执行命令。" ;;
    zh:local_bin_section) printf '%s\n' "~/.local/bin" ;;
    zh:local_bin_note) printf '%s\n' "说明: 这是用户目录下最常见的自装命令位置。" ;;
    zh:npm_bin_section) printf '%s\n' "~/.npm-global/bin" ;;
    zh:npm_bin_note) printf '%s\n' "说明: 这里放的是 npm -g 安装出来的命令入口。" ;;
    zh:homebrew_bin_section) printf '%s\n' "/opt/homebrew/bin" ;;
    zh:homebrew_bin_note) printf '%s\n' "说明: 这里放的是通过 Homebrew 安装的常用命令。" ;;
    zh:cargo_section) printf '%s\n' "~/.cargo/bin" ;;
    zh:cargo_note) printf '%s\n' "说明: Rust / Cargo 安装的工具。" ;;
    zh:go_section) printf '%s\n' "~/go/bin" ;;
    zh:go_note) printf '%s\n' "说明: Go install 安装的命令。" ;;
    zh:conda_section) printf '%s\n' "Conda 环境" ;;
    zh:conda_note) printf '%s\n' "说明: Conda / Miniconda 安装的包。" ;;
    zh:mise_section) printf '%s\n' "mise / asdf" ;;
    zh:mise_note) printf '%s\n' "说明: 多版本运行时管理器安装的 shims。" ;;
    zh:other_section) printf '%s\n' "其他目录" ;;
    zh:other_note) printf '%s\n' "说明: 其他常见安装位置。" ;;
    zh:brew_formulas) printf '%s\n' "Homebrew 包" ;;
    zh:brew_formulas_note) printf '%s\n' "说明: 这一段列的是 brew 安装的命令行工具和版本。" ;;
    zh:npm_packages) printf '%s\n' "npm 全局包" ;;
    zh:npm_packages_note) printf '%s\n' "说明: 这一段列的是通过 npm 全局安装的包。" ;;
    zh:pip_packages) printf '%s\n' "pip 用户包" ;;
    zh:pip_packages_note) printf '%s\n' "说明: 这一段列的是 pip --user 安装的 Python 包。" ;;
    zh:path_entries) printf '%s\n' "PATH 目录" ;;
    zh:path_entries_note) printf '%s\n' "说明: 终端会按这里的顺序查找命令，排在前面的目录优先级更高。" ;;
    zh:none_found) printf '%s\n' "未找到" ;;
    zh:missing) printf '%s\n' "不存在" ;;
    zh:brew_failed) printf '%s\n' "brew list 失败" ;;
    zh:brew_missing) printf '%s\n' "未找到 brew" ;;
    zh:npm_failed) printf '%s\n' "npm ls 失败" ;;
    zh:npm_missing) printf '%s\n' "未找到 npm" ;;
    zh:pip_failed) printf '%s\n' "pip list 失败" ;;
    zh:python_missing) printf '%s\n' "未找到 python3" ;;
    zh:version_unknown) printf '%s\n' "未知版本" ;;
    zh:version_timeout) printf '%s\n' "获取超时" ;;
    zh:version_error) printf '%s\n' "获取失败" ;;
    zh:extended_scan_note) printf '%s\n' "扩展扫描模式已启用，包含更多安装目录。" ;;
    en:summary) printf '%s\n' "Quick Summary" ;;
    en:local_bin) printf '%s\n' "local bin" ;;
    en:npm_bin) printf '%s\n' "npm global" ;;
    en:homebrew_bin) printf '%s\n' "homebrew" ;;
    en:summary_note) printf '%s\n' "Note: These usually map to user-installed commands, npm global commands, and Homebrew commands." ;;
    en:found_commands) printf '%s\n' "Found Commands" ;;
    en:found_commands_note) printf '%s\n' "Note: This section only shows executables actually found in the common install directories." ;;
    en:local_bin_section) printf '%s\n' "~/.local/bin" ;;
    en:local_bin_note) printf '%s\n' "Note: This is the most common location for user-installed commands." ;;
    en:npm_bin_section) printf '%s\n' "~/.npm-global/bin" ;;
    en:npm_bin_note) printf '%s\n' "Note: This directory contains command entry points created by npm -g." ;;
    en:homebrew_bin_section) printf '%s\n' "/opt/homebrew/bin" ;;
    en:homebrew_bin_note) printf '%s\n' "Note: This directory contains commands installed through Homebrew." ;;
    en:cargo_section) printf '%s\n' "~/.cargo/bin" ;;
    en:cargo_note) printf '%s\n' "Note: Tools installed via Rust / Cargo." ;;
    en:go_section) printf '%s\n' "~/go/bin" ;;
    en:go_note) printf '%s\n' "Note: Commands installed via go install." ;;
    en:conda_section) printf '%s\n' "Conda Environments" ;;
    en:conda_note) printf '%s\n' "Note: Packages installed via Conda / Miniconda." ;;
    en:mise_section) printf '%s\n' "mise / asdf" ;;
    en:mise_note) printf '%s\n' "Note: Shims from multi-version runtime managers." ;;
    en:other_section) printf '%s\n' "Other Directories" ;;
    en:other_note) printf '%s\n' "Note: Other common install locations." ;;
    en:brew_formulas) printf '%s\n' "Homebrew Formulas" ;;
    en:brew_formulas_note) printf '%s\n' "Note: This section lists command-line packages and versions installed by brew." ;;
    en:npm_packages) printf '%s\n' "npm Global Packages" ;;
    en:npm_packages_note) printf '%s\n' "Note: This section lists packages installed globally with npm." ;;
    en:pip_packages) printf '%s\n' "pip User Packages" ;;
    en:pip_packages_note) printf '%s\n' "Note: This section lists Python packages installed with pip --user." ;;
    en:path_entries) printf '%s\n' "PATH Entries" ;;
    en:path_entries_note) printf '%s\n' "Note: Your shell searches these directories in order. Earlier entries win." ;;
    en:none_found) printf '%s\n' "none found" ;;
    en:missing) printf '%s\n' "missing" ;;
    en:brew_failed) printf '%s\n' "brew list failed" ;;
    en:brew_missing) printf '%s\n' "brew not found" ;;
    en:npm_failed) printf '%s\n' "npm ls failed" ;;
    en:npm_missing) printf '%s\n' "npm not found" ;;
    en:pip_failed) printf '%s\n' "pip list failed" ;;
    en:python_missing) printf '%s\n' "python3 not found" ;;
    en:version_unknown) printf '%s\n' "unknown version" ;;
    en:version_timeout) printf '%s\n' "timeout" ;;
    en:version_error) printf '%s\n' "failed" ;;
    en:extended_scan_note) printf '%s\n' "Extended scan mode enabled, including more install directories." ;;
    *)
      printf '%s\n' "$key"
      ;;
  esac
}

# ============================================================================
# 输出辅助函数
# ============================================================================

print_section() {
  printf '\n[%s]\n' "$1"
}

print_kv() {
  printf '%-16s %s\n' "$1" "$2"
}

print_kvv() {
  # key + version + path 三列输出
  printf '%-18s %-14s %s\n' "$1" "$2" "$3"
}

print_note() {
  [[ "$QUIET_MODE" == true ]] && return
  printf '%s\n' "$1"
}

# ============================================================================
# 超时工具（兼容 macOS，零外部依赖）
# ============================================================================

# 检测可用的超时命令
TIMEOUT_CMD=""
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD="gtimeout"
fi

# 使用 Bash 内置实现 1 秒超时执行命令
# 参数: 要执行的命令及参数
# 输出: 命令的标准输出+标准错误
# 返回: 0=成功, 124=超时, 其他=命令退出码
run_with_timeout() {
  local cmd_output cmd_exit cmd_pid

  if [[ -n "$TIMEOUT_CMD" ]]; then
    "$TIMEOUT_CMD" 1 "$@" 2>&1
    return $?
  fi

  # 纯 Bash 后备方案
  cmd_output=""
  cmd_exit=0

  {
    "$@" 2>&1
  } &
  cmd_pid=$!

  # 等待最多 1 秒
  if ! wait "$cmd_pid" 2>/dev/null; then
    kill "$cmd_pid" 2>/dev/null || true
    wait "$cmd_pid" 2>/dev/null || true
    return 124
  fi

  # 获取退出码
  wait "$cmd_pid" 2>/dev/null || cmd_exit=$?
  return $cmd_exit
}

# ============================================================================
# 版本获取
# ============================================================================

# 尝试获取命令的版本信息
# 返回: 版本字符串或错误标记
get_command_version() {
  local cmd="$1"
  local version_output=""
  local exit_code=0

  # 对一些已知有特殊行为的命令做预处理
  case "$cmd" in
    python*|pip*)
      version_output="$(run_with_timeout "$cmd" --version)" || exit_code=$?
      ;;
    go|cargo|rustc|node|npm|pnpm|yarn|brew|gh|docker|kubectl|helm|terraform|aws|gcloud|uv|uvx)
      version_output="$(run_with_timeout "$cmd" --version)" || {
        version_output="$(run_with_timeout "$cmd" -V)" || exit_code=$?
      }
      ;;
    *)
      # 通用策略：先 --version 后 -V
      version_output="$(run_with_timeout "$cmd" --version)" || {
        version_output="$(run_with_timeout "$cmd" -V)" || exit_code=$?
      }
      ;;
  esac

  # 处理超时 (exit code 124)
  if [[ $exit_code -eq 124 ]]; then
    printf '%s' "$(t version_timeout)"
    return
  fi

  # 处理失败
  if [[ $exit_code -ne 0 ]] || [[ -z "$version_output" ]]; then
    printf '%s' "$(t version_error)"
    return
  fi

  # 清理版本输出：提取版本号
  # 策略：取第一行，然后尝试提取看起来像版本号的片段
  local first_line="${version_output%%$'\n'*}"

  # 尝试匹配常见版本格式 (x.y.z, vx.y.z, version x.y.z)
  if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+)?) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
  elif [[ "$first_line" =~ [Vv]ersion[[:space:]]*([0-9]+(\.[0-9]+)*) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
  else
    # 如果实在提取不出，返回前 30 个字符
    printf '%s' "${first_line:0:30}"
  fi
}

# ============================================================================
# 命令发现与展示
# ============================================================================

# 根据目录路径判断它属于哪个分类，返回对应的 section key 和 note key
classify_directory() {
  local dir="$1"
  case "$dir" in
    "$HOME/.local/bin")
      printf '%s\t%s\n' "local_bin_section" "local_bin_note"
      ;;
    "$HOME/.npm-global/bin")
      printf '%s\t%s\n' "npm_bin_section" "npm_bin_note"
      ;;
    "/opt/homebrew/bin"|"/home/linuxbrew/.linuxbrew/bin")
      printf '%s\t%s\n' "homebrew_bin_section" "homebrew_bin_note"
      ;;
    "$HOME/.cargo/bin")
      printf '%s\t%s\n' "cargo_section" "cargo_note"
      ;;
    "$HOME/go/bin")
      printf '%s\t%s\n' "go_section" "go_note"
      ;;
    "$HOME/miniconda3/bin"|"$HOME/anaconda3/bin"|"$HOME/.local/pipx"*)
      printf '%s\t%s\n' "conda_section" "conda_note"
      ;;
    "$HOME/.local/share/mise/shims"|"$HOME/.asdf/shims")
      printf '%s\t%s\n' "mise_section" "mise_note"
      ;;
    *)
      printf '%s\t%s\n' "other_section" "other_note"
      ;;
  esac
}

# 打印单个目录中的命令
print_dir_commands() {
  local dir="$1"
  local found=0

  [[ -d "$dir" ]] || return 1

  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    local name version_str
    name="$(basename "$path")"

    if [[ "$SHOW_VERSION" == true ]]; then
      version_str="$(get_command_version "$name")"
      print_kvv "$name" "$version_str" "$path"
    else
      print_kv "$name" "$path"
    fi
    found=1
  done < <(find "$dir" -mindepth 1 -maxdepth 1 \( -type f -o -type l \) -perm -111 | sort)

  return $((1 - found))
}

# 打印所有发现的命令（按目录分组）
print_found_commands_grouped() {
  local all_dirs=("${DEFAULT_SCAN_DIRS[@]}")

  if [[ "$SCAN_ALL" == true ]]; then
    all_dirs+=("${EXTENDED_SCAN_DIRS[@]}")
  fi

  local dir found_any=0
  local section_key note_key

  for dir in "${all_dirs[@]}"; do
    [[ -d "$dir" ]] || continue

    # 获取分类标签
    local classification
    classification="$(classify_directory "$dir")"
    section_key="${classification%%$'\t'*}"
    note_key="${classification##*$'\t'}"

    # 打印该目录的 section
    print_section "$(t "$section_key")"
    if print_dir_commands "$dir"; then
      found_any=1
    else
      printf '%s\n' "$(t none_found)"
    fi
    print_note "$(t "$note_key")"
  done

  if [[ "$found_any" -eq 0 ]]; then
    printf '%s\n' "$(t none_found)"
  fi
}

# 打印扁平化的命令列表（兼容旧版行为，但支持版本）
print_found_commands_flat() {
  local all_dirs=("${DEFAULT_SCAN_DIRS[@]}")

  if [[ "$SCAN_ALL" == true ]]; then
    all_dirs+=("${EXTENDED_SCAN_DIRS[@]}")
  fi

  local dir path name found=0

  for dir in "${all_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      name="$(basename "$path")"

      if [[ "$SHOW_VERSION" == true ]]; then
        local version_str
        version_str="$(get_command_version "$name")"
        print_kvv "$name" "$version_str" "$path"
      else
        print_kv "$name" "$path"
      fi
      found=1
    done < <(find "$dir" -mindepth 1 -maxdepth 1 \( -type f -o -type l \) -perm -111 | sort)
  done

  if [[ "$found" -eq 0 ]]; then
    printf '%s\n' "$(t none_found)"
  fi
}

list_dir_names() {
  local dir="$1"
  if [[ -d "$dir" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -exec basename {} \; | sort
  else
    printf '%s\n' "$(t missing)"
  fi
}

# ============================================================================
# 主输出
# ============================================================================

print_section "$(t summary)"
print_kv "$(t local_bin)" "$HOME/.local/bin"
print_kv "$(t npm_bin)" "$HOME/.npm-global/bin"
print_kv "$(t homebrew_bin)" "/opt/homebrew/bin"
print_note "$(t summary_note)"

if [[ "$SCAN_ALL" == true ]]; then
  print_note "$(t extended_scan_note)"
fi

print_section "$(t found_commands)"
print_found_commands_flat
print_note "$(t found_commands_note)"

if [[ "$QUIET_MODE" != true ]]; then
  print_section "$(t local_bin_section)"
  list_dir_names "$HOME/.local/bin"
  print_note "$(t local_bin_note)"

  print_section "$(t npm_bin_section)"
  list_dir_names "$HOME/.npm-global/bin"
  print_note "$(t npm_bin_note)"

  print_section "$(t homebrew_bin_section)"
  list_dir_names "/opt/homebrew/bin"
  print_note "$(t homebrew_bin_note)"
fi

print_section "$(t brew_formulas)"
if command -v brew >/dev/null 2>&1; then
  brew list --formula --versions 2>/dev/null || printf '%s\n' "$(t brew_failed)"
else
  printf '%s\n' "$(t brew_missing)"
fi
print_note "$(t brew_formulas_note)"

print_section "$(t npm_packages)"
if command -v npm >/dev/null 2>&1; then
  npm ls -g --depth=0 --prefix "$HOME/.npm-global" 2>/dev/null || printf '%s\n' "$(t npm_failed)"
else
  printf '%s\n' "$(t npm_missing)"
fi
print_note "$(t npm_packages_note)"

print_section "$(t pip_packages)"
if command -v python3 >/dev/null 2>&1; then
  python3 -m pip list --user 2>/dev/null || printf '%s\n' "$(t pip_failed)"
else
  printf '%s\n' "$(t python_missing)"
fi
print_note "$(t pip_packages_note)"

if [[ "$QUIET_MODE" != true ]]; then
  print_section "$(t path_entries)"
  printf '%s\n' "$PATH" | tr ':' '\n'
  print_note "$(t path_entries_note)"
fi
