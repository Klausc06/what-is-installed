#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real install directory
real="$0"
while [ -L "$real" ]; do
  target="$(readlink "$real")"
  case "$target" in
    /*) real="$target" ;;
    *)  real="$(cd "$(dirname "$real")" && pwd)/$target" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$real")" && pwd)"

# ── shared libraries ────────────────────────────────────
source "$SCRIPT_DIR/../lib/detect.sh"
source "$SCRIPT_DIR/../lib/render.sh"
source "$SCRIPT_DIR/../lib/shared.sh"

# ── platform-specific code ──────────────────────────────
case "$_PLATFORM_OS" in
  macos)   source "$SCRIPT_DIR/../lib/platform/macos.sh" ;;
  linux)   source "$SCRIPT_DIR/../lib/platform/linux.sh" ;;
  bsd)     source "$SCRIPT_DIR/../lib/platform/bsd.sh" ;;
  mingw|cygwin) source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
  *)       source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
esac

# ── providers ───────────────────────────────────────────
source "$SCRIPT_DIR/../lib/providers/cargo.sh"
source "$SCRIPT_DIR/../lib/providers/brew.sh"
source "$SCRIPT_DIR/../lib/providers/resolve.sh"
source "$SCRIPT_DIR/../lib/providers/_common.sh"
source "$SCRIPT_DIR/../lib/providers/winget.sh"
source "$SCRIPT_DIR/../lib/providers/scoop.sh"
source "$SCRIPT_DIR/../lib/providers/choco.sh"
source "$SCRIPT_DIR/../lib/providers/rpm.sh"
source "$SCRIPT_DIR/../lib/providers/pacman.sh"
source "$SCRIPT_DIR/../lib/providers/apt.sh"
source "$SCRIPT_DIR/../lib/providers/snap.sh"
source "$SCRIPT_DIR/../lib/providers/flatpak.sh"

# ── main ──────────────────────────────────────────────

NO_COLOR="${NO_COLOR:-}" ASCII_MODE="${ASCII_MODE:-}"
setup_colors
setup_glyphs

resolve_providers

_seen_names_str=$'\n'
_seen_family_ver_str=$'\n'
_PROBE_COUNT=0

ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

SYSTEM_DIRS="$(get_system_dirs)"
FAMILY_SKIP="$(get_family_skip_patterns)"

PATH_DIRS=()
_seen_dirs=$'\n'
OLD_IFS="$IFS"
IFS=':'
for dir in $PATH; do
  [[ "$_seen_dirs" == *$'\n'"$dir"$'\n'* ]] && continue
  _seen_dirs+="$dir"$'\n'
  PATH_DIRS+=("$dir")
done
IFS="$OLD_IFS"

for dir in "${PATH_DIRS[@]}"; do
  [[ "$dir" =~ $SYSTEM_DIRS || -z "$dir" || ! -d "$dir" ]] && continue

  label="$(section_label "$dir")"
  section_items_before=${#ALL_SECTION_ITEMS[@]}
  has_items=false

  shopt -s nullglob
  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    [[ "$_seen_names_str" == *$'\n'"$name"$'\n'* ]] && continue

    if [[ -n "$FAMILY_SKIP" && "$name" =~ $FAMILY_SKIP ]]; then
      continue
    fi

    case "$name" in
      *-config|*.py) continue ;;
    esac

    # Skip the tool itself (prevents recursive probing)
    [[ "$name" == "what-is-installed" ]] && continue

    family="${name%-*}"
    [[ "$family" == "$name" ]] && family="${name%%[0-9]*}"
    [[ "$family" == "$name" ]] && family=""

    get_command_version "$name"
    ver="$VERSION_RESULT"
    [[ "$ver" == "-" ]] && continue

    if [[ -n "$family" ]]; then
      [[ "$_seen_family_ver_str" == *$'\n'"$family|$ver"$'\n'* ]] && continue
    fi

    _seen_names_str+="$name"$'\n'
    [[ -n "$family" ]] && _seen_family_ver_str+="$family|$ver"$'\n'

    ALL_SECTION_ITEMS+=("$name|$ver|$path")
    has_items=true
  done
  shopt -u nullglob

  if [[ "$has_items" == true ]]; then
    count=$(( ${#ALL_SECTION_ITEMS[@]} - section_items_before ))
    ALL_SECTION_DIRS+=("$label")
    ALL_SECTION_START+=("$section_items_before")
    ALL_SECTION_COUNTS+=("$count")
  fi
done

[[ ${_PROBE_COUNT:-0} -gt 0 ]] && printf '\n' >&2

# ── render ──────────────────────────────────────────────

render_table
