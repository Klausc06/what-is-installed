#!/usr/bin/env bash
set -euo pipefail

# what-is-installed — 命令行工具扫描器
# 扫描 $PATH 中所有目录，展示实际可用的命令及其版本

usage() {
  cat <<'EOF'
Usage: what-is-installed [OPTIONS]

Options:
  --help, -h     Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    *) printf 'Unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

print_kvv() { printf '%-18s %-14s %s\n' "$1" "$2" "$3"; }

# 版本缓存（并行数组，兼容 bash 3.2）
CACHE_NAMES=("")
CACHE_VALS=("")

get_command_version() {
  local cmd="$1"
  local i
  for i in "${!CACHE_NAMES[@]}"; do
    [[ "${CACHE_NAMES[$i]}" == "$cmd" ]] && { VERSION_RESULT="${CACHE_VALS[$i]}"; return; }
  done

  local output exit_code=0
  output="$("$cmd" --version 2>/dev/null)" || {
    output="$("$cmd" -V 2>/dev/null)" || exit_code=$?
  }

  local result
  if [[ $exit_code -ne 0 || -z "$output" ]]; then
    result="-"
  else
    local first_line="${output%%$'\n'*}"
    if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+)?) ]]; then
      result="${BASH_REMATCH[1]}"
    elif [[ "$first_line" =~ [Vv]ersion[[:space:]]*([0-9]+(\.[0-9]+)*) ]]; then
      result="${BASH_REMATCH[1]}"
    else
      result="${first_line:0:30}"
    fi
  fi

  CACHE_NAMES+=("$cmd")
  CACHE_VALS+=("$result")
  VERSION_RESULT="$result"
}

printf '\n'

# 去重追踪（并行数组，兼容 bash 3.2）
SEEN_NAMES=("")
SEEN_FAMILIES=("")
SEEN_VERSIONS=("")

system_dirs='^(/bin|/sbin|/usr/bin|/usr/sbin|/System/|/Library/Apple/)'

while IFS= read -r dir; do
  [[ "$dir" =~ $system_dirs || -z "$dir" || ! -d "$dir" ]] && continue

  section_printed=false

  # glob 替代 find，避免每个目录 spawn 子进程
  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    get_command_version "$name"
    ver="$VERSION_RESULT"
    [[ "$ver" == "-" ]] && continue

    # 1. 同名去重
    found=false
    for seen in "${SEEN_NAMES[@]}"; do
      [[ "$seen" == "$name" ]] && { found=true; break; }
    done
    [[ "$found" == true ]] && continue

    # 2. 同家族前缀 + 同版本 → 变体去重
    family="${name%-*}"
    [[ "$family" == "$name" ]] && family=""
    if [[ -n "$family" ]]; then
      skip=false
      for j in "${!SEEN_FAMILIES[@]}"; do
        [[ "${SEEN_FAMILIES[$j]}" == "$family" && "${SEEN_VERSIONS[$j]}" == "$ver" ]] && { skip=true; break; }
      done
      [[ "$skip" == true ]] && continue
    fi

    # 3. 通用变体/辅助文件
    case "$name" in
      *-intel64|*-arm64|*-config|*.py) continue ;;
    esac

    SEEN_NAMES+=("$name")
    [[ -n "$family" ]] && { SEEN_FAMILIES+=("$family"); SEEN_VERSIONS+=("$ver"); }

    if [[ "$section_printed" == false ]]; then
      case "$dir" in
        */.local/bin)        printf '[User Local]\n' ;;
        */.npm-global/bin)   printf '[npm Global]\n' ;;
        /opt/homebrew/bin)   printf '[Homebrew]\n' ;;
        */Library/Frameworks/Python.framework/*/bin) printf '[Python Framework]\n' ;;
        */usr/local/bin|*/usr/local/sbin) printf '[System Local]\n' ;;
        *)                   printf '[Other]\n' ;;
      esac
      section_printed=true
    fi

    print_kvv "$name" "$ver" "$path"
  done

  [[ "$section_printed" == true ]] && printf '\n'
done < <(printf '%s\n' "$PATH" | tr ':' '\n' | sort -u)
