#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real install directory
real="$0"
while [ -L "$real" ]; do
  target="$(readlink "$real")"
  case "$target" in
    /*) real="$target" ;;
    *)  real="$(cd "$(dirname "$real")" && pwd)/$target" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$real")" && pwd)"

# ── shared libraries ────────────────────────────────────
source "$SCRIPT_DIR/../lib/detect.sh"
source "$SCRIPT_DIR/../lib/render.sh"
source "$SCRIPT_DIR/../lib/shared.sh"

# ── platform-specific code ──────────────────────────────
case "$_PLATFORM_OS" in
  macos)   source "$SCRIPT_DIR/../lib/platform/macos.sh" ;;
  linux)   source "$SCRIPT_DIR/../lib/platform/linux.sh" ;;
  bsd)     source "$SCRIPT_DIR/../lib/platform/bsd.sh" ;;
  mingw|cygwin) source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
  *)       source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
esac

# ── providers ───────────────────────────────────────────
source "$SCRIPT_DIR/../lib/providers/cargo.sh"
source "$SCRIPT_DIR/../lib/providers/resolve.sh"

# ── main ──────────────────────────────────────────────

NO_COLOR="${NO_COLOR:-}" ASCII_MODE="${ASCII_MODE:-}"
setup_colors
setup_glyphs

resolve_providers

SEEN_NAMES=()
SEEN_FAMILIES=()
SEEN_VERSIONS=()
SEEN_PATH_DIRS=()
_PROBE_COUNT=0

ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

SYSTEM_DIRS="$(get_system_dirs)"
FAMILY_SKIP="$(get_family_skip_patterns)"

PATH_DIRS=()
OLD_IFS="$IFS"
IFS=':'
for dir in $PATH; do
  duplicate_dir=false
  if [[ ${#SEEN_PATH_DIRS[@]} -gt 0 ]]; then
    for seen_dir in "${SEEN_PATH_DIRS[@]}"; do
      [[ "$seen_dir" == "$dir" ]] && { duplicate_dir=true; break; }
    done
  fi
  [[ "$duplicate_dir" == true ]] && continue
  SEEN_PATH_DIRS+=("$dir")
  PATH_DIRS+=("$dir")
done
IFS="$OLD_IFS"

for dir in "${PATH_DIRS[@]}"; do
  [[ "$dir" =~ $SYSTEM_DIRS || -z "$dir" || ! -d "$dir" ]] && continue

  label="$(section_label "$dir")"
  section_items_before=${#ALL_SECTION_ITEMS[@]}
  has_items=false

  shopt -s nullglob
  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    # Filter 1: Name dedup
    found=false
    if [[ ${#SEEN_NAMES[@]} -gt 0 ]]; then
      for seen in "${SEEN_NAMES[@]}"; do
        [[ "$seen" == "$name" ]] && { found=true; break; }
      done
    fi
    [[ "$found" == true ]] && continue

    # Filter 2: Architecture suffix skip
    if [[ -n "$FAMILY_SKIP" && "$name" =~ $FAMILY_SKIP ]]; then
      continue
    fi

    # Filter 3: Blocklist patterns
    case "$name" in
      *-config|*.py) continue ;;
    esac

    # Filter 4: Extract family prefix
    family="${name%-*}"
    [[ "$family" == "$name" ]] && family="${name%%[0-9]*}"
    [[ "$family" == "$name" ]] && family=""

    # Now probe version — only for commands that passed ALL filters
    get_command_version "$name"
    ver="$VERSION_RESULT"
    [[ "$ver" == "-" ]] && continue

    # Filter 5: Family+version dedup (needs version from probe)
    if [[ -n "$family" ]]; then
      skip=false
      for j in "${!SEEN_FAMILIES[@]}"; do
        [[ "${SEEN_FAMILIES[$j]}" == "$family" && "${SEEN_VERSIONS[$j]}" == "$ver" ]] && { skip=true; break; }
      done
      [[ "$skip" == true ]] && continue
    fi

    SEEN_NAMES+=("$name")
    [[ -n "$family" ]] && { SEEN_FAMILIES+=("$family"); SEEN_VERSIONS+=("$ver"); }

    ALL_SECTION_ITEMS+=("$name|$ver|$path")
    has_items=true
  done
  shopt -u nullglob

  if [[ "$has_items" == true ]]; then
    count=$(( ${#ALL_SECTION_ITEMS[@]} - section_items_before ))
    ALL_SECTION_DIRS+=("$label")
    ALL_SECTION_START+=("$section_items_before")
    ALL_SECTION_COUNTS+=("$count")
  fi
done

[[ ${_PROBE_COUNT:-0} -gt 0 ]] && printf '\n' >&2

# ── render ──────────────────────────────────────────────

render_table
