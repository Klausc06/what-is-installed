#!/usr/bin/env bash
set -euo pipefail

# what-is-installed — 命令行工具扫描器

# ============================================================================
# 扫描目录配置
# ============================================================================

SCAN_DIRS=(
  "$HOME/.local/bin"
  "$HOME/.npm-global/bin"
  "/opt/homebrew/bin"
  "$HOME/.cargo/bin"
  "$HOME/go/bin"
  "$HOME/.local/pipx/venvs"
  "$HOME/.local/bin/pipx"
  "$HOME/miniconda3/bin"
  "$HOME/anaconda3/bin"
  "$HOME/.local/share/mise/shims"
  "$HOME/.asdf/shims"
  "/home/linuxbrew/.linuxbrew/bin"
  "$HOME/Library/pnpm"
  "/usr/local/bin"
  "/usr/local/sbin"
)

# ============================================================================
# 参数解析
# ============================================================================

usage() {
  cat <<'EOF'
Usage: what-is-installed [OPTIONS]

Options:
  --help, -h     显示帮助信息
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf '未知参数: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# ============================================================================
# 输出辅助函数
# ============================================================================

print_section() {
  printf '\n[%s]\n' "$1"
}

print_kvv() {
  printf '%-18s %-14s %s\n' "$1" "$2" "$3"
}

# ============================================================================
# 超时工具（兼容 macOS）
# ============================================================================

TIMEOUT_CMD=""
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD="gtimeout"
fi

run_with_timeout() {
  if [[ -n "$TIMEOUT_CMD" ]]; then
    "$TIMEOUT_CMD" 1 "$@" 2>&1
    return $?
  fi

  local cmd_pid
  {
    "$@" 2>&1
  } &
  cmd_pid=$!

  if ! wait "$cmd_pid" 2>/dev/null; then
    kill "$cmd_pid" 2>/dev/null || true
    wait "$cmd_pid" 2>/dev/null || true
    return 124
  fi

  wait "$cmd_pid" 2>/dev/null || return $?
}

# ============================================================================
# 版本获取
# ============================================================================

get_command_version() {
  local cmd="$1"
  local version_output=""
  local exit_code=0

  case "$cmd" in
    python*|pip*)
      version_output="$(run_with_timeout "$cmd" --version)" || exit_code=$?
      ;;
    *)
      version_output="$(run_with_timeout "$cmd" --version)" || {
        version_output="$(run_with_timeout "$cmd" -V)" || exit_code=$?
      }
      ;;
  esac

  if [[ $exit_code -eq 124 ]]; then
    printf '%s' "获取超时"
    return
  fi

  if [[ $exit_code -ne 0 ]] || [[ -z "$version_output" ]]; then
    printf '%s' "获取失败"
    return
  fi

  local first_line="${version_output%%$'\n'*}"

  if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+)?) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
  elif [[ "$first_line" =~ [Vv]ersion[[:space:]]*([0-9]+(\.[0-9]+)*) ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
  else
    printf '%s' "${first_line:0:30}"
  fi
}

# ============================================================================
# 命令发现
# ============================================================================

print_found_commands() {
  local dir path name found=0

  for dir in "${SCAN_DIRS[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      name="$(basename "$path")"

      local version_str
      version_str="$(get_command_version "$name")"
      print_kvv "$name" "$version_str" "$path"
      found=1
    done < <(find "$dir" -mindepth 1 -maxdepth 1 \( -type f -o -type l \) -perm -111 | sort)
  done

  if [[ "$found" -eq 0 ]]; then
    printf '%s\n' "未找到"
  fi
}

# ============================================================================
# 主输出
# ============================================================================

print_section "已发现的命令"
print_found_commands

print_section "Homebrew 包"
if command -v brew >/dev/null 2>&1; then
  brew list --formula --versions 2>/dev/null || printf '%s\n' "brew list 失败"
else
  printf '%s\n' "未找到 brew"
fi

print_section "npm 全局包"
if command -v npm >/dev/null 2>&1; then
  npm ls -g --depth=0 --prefix "$HOME/.npm-global" 2>/dev/null || printf '%s\n' "npm ls 失败"
else
  printf '%s\n' "未找到 npm"
fi

print_section "pip 用户包"
if command -v python3 >/dev/null 2>&1; then
  python3 -m pip list --user 2>/dev/null || printf '%s\n' "pip list 失败"
else
  printf '%s\n' "未找到 python3"
fi
