#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real install directory
real="$0"
while [ -L "$real" ]; do
  target="$(readlink "$real")"
  case "$target" in
    /*) real="$target" ;;
    *)  real="$(cd "$(dirname "$real")" && pwd)/$target" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$real")" && pwd)"
source "$SCRIPT_DIR/../lib/platform.sh"
source "$SCRIPT_DIR/../lib/render.sh"

short_path() {
  local p="$1"
  p="${p/#$HOME/~}"
  printf '%s' "$p"
}

repeat_char() {
  local char="$1" count="$2" out=""
  while [[ $count -gt 0 ]]; do
    out+="$char"
    ((count--))
  done
  printf '%s' "$out"
}

CACHE_NAMES=()
CACHE_VALS=()

escape_cache_field() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//$'\t'/\\t}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\n'/\\n}"
  printf '%s' "$value"
}

unescape_cache_field() {
  local value="$1" out="" i=0 char next
  while [[ $i -lt ${#value} ]]; do
    char="${value:$i:1}"
    if [[ "$char" == '\' && $((i + 1)) -lt ${#value} ]]; then
      next="${value:$((i + 1)):1}"
      case "$next" in
        t) out+=$'\t' ;;
        r) out+=$'\r' ;;
        n) out+=$'\n' ;;
        '\') out+='\' ;;
        *) out+="\\$next" ;;
      esac
      i=$((i + 2))
    else
      out+="$char"
      i=$((i + 1))
    fi
  done
  printf '%s' "$out"
}

write_cache() {
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/what-is-installed"
  local i tmp
  mkdir -p "$cache_dir"
  tmp="$(mktemp "$cache_dir/.versions.XXXXXX")"
  {
    printf 'ts\t%s\n' "$(date +%s)"
    if [[ ${#CACHE_NAMES[@]} -gt 0 ]]; then
      for i in "${!CACHE_NAMES[@]}"; do
        printf 'entry\t%s\t%s\n' \
          "$(escape_cache_field "${CACHE_NAMES[$i]}")" \
          "$(escape_cache_field "${CACHE_VALS[$i]}")"
      done
    fi
  } > "$tmp" && mv "$tmp" "$cache_dir/versions.cache"
}

load_cache() {
  local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/what-is-installed/versions.cache"
  [[ -f "$cache_file" ]] || return 1
  local now cache_ts="" kind name val
  now=$(date +%s)

  CACHE_NAMES=()
  CACHE_VALS=()

  while IFS=$'\t' read -r kind name val _; do
    case "$kind" in
      ts)
        [[ "${name:-}" =~ ^[0-9]+$ ]] || return 1
        cache_ts="$name"
        ;;
      entry)
        [[ -n "$cache_ts" && -n "${name:-}" ]] || continue
        CACHE_NAMES+=("$(unescape_cache_field "$name")")
        CACHE_VALS+=("$(unescape_cache_field "${val:-}")")
        ;;
    esac
  done < "$cache_file"

  [[ -n "$cache_ts" && $(( now - cache_ts )) -lt 3600 ]] || return 1
}

run_with_timeout() {
  local timeout="${1:-2}" tmpfile pid exit_code waited
  shift
  tmpfile="$(mktemp)"

  # Prefer GNU timeout if available (fast, reliable across platforms)
  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout" "$@" >"$tmpfile" 2>&1
    exit_code=$?
  else
    # Fallback: foreground polling loop — no background kill needed
    # (background { sleep; kill; } & fails on Windows Git Bash)
    "$@" >"$tmpfile" 2>&1 &
    pid=$!
    waited=0
    while kill -0 "$pid" 2>/dev/null && [[ $waited -lt $timeout ]]; do
      sleep 1
      ((waited++))
    done
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      rm -f "$tmpfile"
      return 124
    fi
    wait "$pid" 2>/dev/null
    exit_code=$?
  fi

  if [[ $exit_code -eq 124 || $exit_code -eq 143 || $exit_code -eq 137 ]]; then
    rm -f "$tmpfile"
    return 124
  fi
  tr -d '\0' <"$tmpfile" 2>/dev/null
  rm -f "$tmpfile"
  return ${exit_code:-0}
}

VERSION_RESULT=""

get_command_version() {
  local cmd="$1" env_prefix output first_line i

  if [[ ${#CACHE_NAMES[@]} -gt 0 ]]; then
    for i in "${!CACHE_NAMES[@]}"; do
      [[ "${CACHE_NAMES[$i]}" == "$cmd" ]] && { VERSION_RESULT="${CACHE_VALS[$i]}"; return; }
    done
  fi

  env_prefix="$(get_accel_env "$cmd")"

  if [[ -n "$env_prefix" ]]; then
    output="$(run_with_timeout 1 env $env_prefix "$cmd" --version)" || true
    [[ -z "$output" ]] && output="$(run_with_timeout 1 env $env_prefix "$cmd" -V)" || true
  else
    output="$(run_with_timeout 1 "$cmd" --version)" || true
    [[ -z "$output" ]] && output="$(run_with_timeout 1 "$cmd" -V)" || true
  fi

  local result
  if [[ -z "$output" ]]; then
    result="-"
  else
    if command -v iconv >/dev/null 2>&1 && ! printf '%s' "$output" | iconv -f utf-8 -t utf-8 >/dev/null 2>&1; then
      output="$(printf '%s' "$output" | iconv -f latin1 -t utf-8 2>/dev/null || printf '%s' "$output")"
    fi

    first_line="${output%%$'\n'*}"
    if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+){1,2}) ]]; then
      result="${BASH_REMATCH[1]}"
    elif [[ "$first_line" =~ [Vv]ersion[[:space:]]+([0-9]+(\.[0-9]+)+) ]]; then
      result="${BASH_REMATCH[1]}"
    else
      result="-"
    fi
  fi

  CACHE_NAMES+=("$cmd")
  CACHE_VALS+=("$result")
  VERSION_RESULT="$result"
}

# ── main ──────────────────────────────────────────────

NO_COLOR="${NO_COLOR:-}" ASCII_MODE="${ASCII_MODE:-}"
setup_colors
setup_glyphs

FIRST_RUN=false
load_cache || FIRST_RUN=true

if $FIRST_RUN; then
  echo "  (first run — probing versions, may take a few seconds...)" >&2
  echo >&2
fi

SEEN_NAMES=()
SEEN_FAMILIES=()
SEEN_VERSIONS=()
SEEN_PATH_DIRS=()

ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

SYSTEM_DIRS="$(get_system_dirs)"
FAMILY_SKIP="$(get_family_skip_patterns)"

PATH_DIRS=()
OLD_IFS="$IFS"
IFS=':'
for dir in $PATH; do
  duplicate_dir=false
  if [[ ${#SEEN_PATH_DIRS[@]} -gt 0 ]]; then
    for seen_dir in "${SEEN_PATH_DIRS[@]}"; do
      [[ "$seen_dir" == "$dir" ]] && { duplicate_dir=true; break; }
    done
  fi
  [[ "$duplicate_dir" == true ]] && continue
  SEEN_PATH_DIRS+=("$dir")
  PATH_DIRS+=("$dir")
done
IFS="$OLD_IFS"

for dir in "${PATH_DIRS[@]}"; do
  [[ "$dir" =~ $SYSTEM_DIRS || -z "$dir" || ! -d "$dir" ]] && continue

  label="$(section_label "$dir")"
  section_items_before=${#ALL_SECTION_ITEMS[@]}
  has_items=false

  shopt -s nullglob
  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    get_command_version "$name"
    ver="$VERSION_RESULT"
    [[ "$ver" == "-" ]] && continue

    found=false
    if [[ ${#SEEN_NAMES[@]} -gt 0 ]]; then
      for seen in "${SEEN_NAMES[@]}"; do
        [[ "$seen" == "$name" ]] && { found=true; break; }
      done
    fi
    [[ "$found" == true ]] && continue

    family="${name%-*}"
    [[ "$family" == "$name" ]] && family="${name%%[0-9]*}"
    [[ "$family" == "$name" ]] && family=""
    if [[ -n "$family" ]]; then
      skip=false
      for j in "${!SEEN_FAMILIES[@]}"; do
        [[ "${SEEN_FAMILIES[$j]}" == "$family" && "${SEEN_VERSIONS[$j]}" == "$ver" ]] && { skip=true; break; }
      done
      [[ "$skip" == true ]] && continue
    fi

    if [[ -n "$FAMILY_SKIP" && "$name" =~ $FAMILY_SKIP ]]; then
      continue
    fi

    case "$name" in
      *-config|*.py) continue ;;
    esac

    SEEN_NAMES+=("$name")
    [[ -n "$family" ]] && { SEEN_FAMILIES+=("$family"); SEEN_VERSIONS+=("$ver"); }

    ALL_SECTION_ITEMS+=("$name|$ver|$path")
    has_items=true
  done
  shopt -u nullglob

  if [[ "$has_items" == true ]]; then
    count=$(( ${#ALL_SECTION_ITEMS[@]} - section_items_before ))
    ALL_SECTION_DIRS+=("$label")
    ALL_SECTION_START+=("$section_items_before")
    ALL_SECTION_COUNTS+=("$count")
  fi
  printf '.' >&2
done
printf '\n' >&2

write_cache || true

# ── render ──────────────────────────────────────────────

render_table
