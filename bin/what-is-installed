#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real install directory
real="$0"
while [ -L "$real" ]; do
  target="$(readlink "$real")"
  case "$target" in
    /*) real="$target" ;;
    *)  real="$(cd "$(dirname "$real")" && pwd)/$target" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$real")" && pwd)"

# ── shared libraries ────────────────────────────────────
source "$SCRIPT_DIR/../lib/detect.sh"
source "$SCRIPT_DIR/../lib/render.sh"
source "$SCRIPT_DIR/../lib/shared.sh"

# ── platform-specific code ──────────────────────────────
case "$_PLATFORM_OS" in
  macos)   source "$SCRIPT_DIR/../lib/platform/macos.sh" ;;
  linux)   source "$SCRIPT_DIR/../lib/platform/linux.sh" ;;
  bsd)     source "$SCRIPT_DIR/../lib/platform/bsd.sh" ;;
  mingw|cygwin) source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
  *)       source "$SCRIPT_DIR/../lib/platform/windows.sh" ;;
esac

# Validate platform contract — all platform files must export these functions.
for _fn in get_system_dirs get_family_skip_patterns get_gui_skip_patterns section_label section_color; do
  if ! declare -F "$_fn" >/dev/null 2>&1; then
    echo "ERROR: platform file missing required function: $_fn" >&2
    exit 1
  fi
done

# ── providers ───────────────────────────────────────────
source "$SCRIPT_DIR/../lib/providers/cargo.sh"
source "$SCRIPT_DIR/../lib/providers/brew.sh"
source "$SCRIPT_DIR/../lib/providers/resolve.sh"
source "$SCRIPT_DIR/../lib/providers/_common.sh"
source "$SCRIPT_DIR/../lib/providers/winget.sh"
source "$SCRIPT_DIR/../lib/providers/scoop.sh"
source "$SCRIPT_DIR/../lib/providers/choco.sh"
source "$SCRIPT_DIR/../lib/providers/rpm.sh"
source "$SCRIPT_DIR/../lib/providers/pacman.sh"
source "$SCRIPT_DIR/../lib/providers/apt.sh"
source "$SCRIPT_DIR/../lib/providers/snap.sh"
source "$SCRIPT_DIR/../lib/providers/flatpak.sh"

# ── main ──────────────────────────────────────────────

NO_COLOR="${NO_COLOR:-}" ASCII_MODE="${ASCII_MODE:-}"
setup_colors
setup_glyphs

ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

SYSTEM_DIRS="$(get_system_dirs)"
FAMILY_SKIP="$(get_family_skip_patterns)"
GUI_SKIP="$(get_gui_skip_patterns)"

PATH_DIRS=()
OLD_IFS="$IFS"
IFS=':'
for dir in $PATH; do
  PATH_DIRS+=("$dir")
done
IFS="$OLD_IFS"

# ── Pass 1: Collect candidates (name-only filters, no version probing) ──
CANDIDATE_NAMES=()
CANDIDATE_PATHS=()
CANDIDATE_SECTIONS=()
_seen_dirs=$'\n'
_seen_names_str=$'\n'

for dir in "${PATH_DIRS[@]}"; do
  [[ "$dir" =~ $SYSTEM_DIRS || -z "$dir" || ! -d "$dir" ]] && continue
  [[ "$_seen_dirs" == *$'\n'"$(_escape_glob "$dir")"$'\n'* ]] && continue
  _seen_dirs+="$dir"$'\n'

  label="$(section_label "$dir")"

  shopt -s nullglob
  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    # Dedup by name
    [[ "$_seen_names_str" == *$'\n'"$(_escape_glob "$name")"$'\n'* ]] && continue

    # Architecture suffix skip
    [[ -n "$FAMILY_SKIP" && "$name" =~ $FAMILY_SKIP ]] && continue

    # GUI-only tool skip (prevents launching windows)
    [[ -n "$GUI_SKIP" && "$name" =~ $GUI_SKIP ]] && continue

    # Blocklist patterns
    case "$name" in
      *-config|*.py|*.sh|*[[]*) continue ;;  # *[[]* = names containing '['
    esac

    # Skip the tool itself (prevents recursive probing)
    [[ "$name" == "what-is-installed" ]] && continue

    _seen_names_str+="$name"$'\n'
    CANDIDATE_NAMES+=("$name")
    CANDIDATE_PATHS+=("$path")
    CANDIDATE_SECTIONS+=("$label")
  done
  shopt -u nullglob
done

TOTAL_CANDIDATES=${#CANDIDATE_NAMES[@]}
[[ $TOTAL_CANDIDATES -eq 0 ]] && { render_table; exit 0; }

# ── Scan phase: build quick table (version=?) ──
_current_section=""
_section_start=0
for ((_si=0; _si<TOTAL_CANDIDATES; _si++)); do
  ALL_SECTION_ITEMS+=("${CANDIDATE_NAMES[$_si]}|?|${CANDIDATE_PATHS[$_si]}")
  this_label="${CANDIDATE_SECTIONS[$_si]}"
  if [[ "$this_label" != "$_current_section" ]]; then
    if [[ -n "$_current_section" ]]; then
      ALL_SECTION_COUNTS+=($(( ${#ALL_SECTION_ITEMS[@]} - 1 - _section_start )))
    fi
    _current_section="$this_label"
    _section_start=$((${#ALL_SECTION_ITEMS[@]} - 1))
    ALL_SECTION_DIRS+=("$_current_section")
    ALL_SECTION_START+=("$_section_start")
  fi
done
if [[ -n "$_current_section" ]]; then
  ALL_SECTION_COUNTS+=($(( ${#ALL_SECTION_ITEMS[@]} - _section_start )))
fi

render_table
printf 'Found %d tools.\n' "$TOTAL_CANDIDATES" >&2

# ── Prompt: probe versions? ──
if [[ -t 1 ]]; then
  printf 'Probe versions? [y/N] ' >&2
  read -r _answer || true
  [[ "$_answer" =~ ^[yY] ]] || exit 0
else
  exit 0
fi

# ── Probe phase: providers + Pass 2 ──
resolve_providers

# Reset section arrays for full probe pass
ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

# ── Pass 2: Parallel probe versions with progress ──
_start_time=$SECONDS
_done=0
_current_section=""
_section_start=0
_seen_family_ver_str=$'\n'
_BATCH_SIZE=32
_PROBE_TMPDIR="$(mktemp -d)" || { echo "ERROR: mktemp failed" >&2; exit 1; }
trap 'rm -rf "$_PROBE_TMPDIR"' EXIT
_LIB_DIR="$SCRIPT_DIR/../lib"

batch=0
while (( batch * _BATCH_SIZE < TOTAL_CANDIDATES )); do
  batch_start=$((batch * _BATCH_SIZE))
  batch_end=$((batch_start + _BATCH_SIZE))
  (( batch_end > TOTAL_CANDIDATES )) && batch_end=$TOTAL_CANDIDATES

  # Launch parallel probes (subshell inherits cache arrays)
  for ((i=batch_start; i<batch_end; i++)); do
    (
      get_command_version "${CANDIDATE_NAMES[$i]}"
      printf '%s' "$VERSION_RESULT" > "$_PROBE_TMPDIR/result_$i"
    ) &
  done
  wait  # block until all probes in this batch finish

  # Serial merge: dedup + section tracking relies on order
  for ((i=batch_start; i<batch_end; i++)); do
    ver="$(cat "$_PROBE_TMPDIR/result_$i" 2>/dev/null)"
    [[ -z "$ver" ]] && continue

    name="${CANDIDATE_NAMES[$i]}"
    path="${CANDIDATE_PATHS[$i]}"
    this_label="${CANDIDATE_SECTIONS[$i]}"

    # Family+version dedup
    family="${name%-*}"
    [[ "$family" == "$name" ]] && family="${name%%[0-9]*}"
    [[ "$family" == "$name" ]] && family=""

    if [[ -n "$family" ]]; then
      [[ "$_seen_family_ver_str" == *$'\n'"$(_escape_glob "$family|$ver")"$'\n'* ]] && continue
    fi
    [[ -n "$family" ]] && _seen_family_ver_str+="$family|$ver"$'\n'

    # Accepted — add to results
    ver_index=${#ALL_SECTION_ITEMS[@]}
    ALL_SECTION_ITEMS+=("$name|$ver|$path")

    # Section boundary tracking
    if [[ "$this_label" != "$_current_section" ]]; then
      if [[ -n "$_current_section" ]]; then
        ALL_SECTION_COUNTS+=($(( ver_index - _section_start )))
      fi
      _current_section="$this_label"
      _section_start=$ver_index
      ALL_SECTION_DIRS+=("$_current_section")
      ALL_SECTION_START+=("$_section_start")
    fi

    _done=$((_done + 1))
  done

  # Progress display (stderr, TTY-guarded)
  if [[ -t 2 ]]; then
    _pct=$(( (_done * 100) / TOTAL_CANDIDATES ))
    _elapsed=$(( SECONDS - _start_time ))
    if (( _done > 0 && _elapsed > 0 )); then
      _eta=$(( (_elapsed * (TOTAL_CANDIDATES - _done)) / _done ))
      if (( _eta >= 60 )); then
        _eta_display="$(( _eta / 60 ))m$(( _eta % 60 ))s"
      else
        _eta_display="${_eta}s"
      fi
    else
      _eta_display="..."
    fi
    printf '\r[%d/%d] %d%% | ETA: %s  ' "$_done" "$TOTAL_CANDIDATES" "$_pct" "$_eta_display" >&2
  fi

  ((batch++))
done


# Close final section
if [[ -n "$_current_section" ]]; then
  ALL_SECTION_COUNTS+=($(( ${#ALL_SECTION_ITEMS[@]} - _section_start )))
fi

# Clear progress line (TTY-guarded)
if [[ -t 2 ]]; then
  printf '\r\033[K' >&2
fi

# ── render ──────────────────────────────────────────────

render_table
