#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../lib/platform.sh"
source "$SCRIPT_DIR/../lib/render.sh"

usage() {
  cat <<'EOF'
Usage: what-is-installed [OPTIONS]

Scan $PATH directories and show available command-line tools with versions.

Options:
  --help, -h              Show this help message and exit
  --no-color              Disable colored output
  --json                  Output as JSON
  --csv                   Output as CSV
  --plain                 Output as plain text (no box drawing)
  --ascii                 Use ASCII characters for box drawing
  --filter <pattern>      Only show commands matching pattern (fuzzy, case-insensitive)
  --sort <field>          Sort by: name, version, path (default: name)
  --no-cache              Skip file cache, always do fresh version probing
  --include-system, -a    Include system directories in scan
EOF
}

NO_COLOR=""
ASCII_MODE=""
OUTPUT_FORMAT="table"
FILTER=""
SORT_FIELD=""
NO_CACHE=""
INCLUDE_SYSTEM=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)            usage; exit 0 ;;
    --no-color)           NO_COLOR=1; shift ;;
    --json)               OUTPUT_FORMAT="json"; shift ;;
    --csv)                OUTPUT_FORMAT="csv"; shift ;;
    --plain)              OUTPUT_FORMAT="plain"; shift ;;
    --ascii)              ASCII_MODE=1; shift ;;
    --filter)             FILTER="$2"; shift 2 ;;
    --sort)               SORT_FIELD="$2"; shift 2 ;;
    --no-cache)           NO_CACHE=1; shift ;;
    --include-system|-a)  INCLUDE_SYSTEM=1; shift ;;
    *)                    printf 'Unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

setup_colors
setup_glyphs

[[ -n "${C_MAGENTA:-}" ]] || C_MAGENTA="$C_RESET"
[[ -n "${C_RED:-}" ]]    || C_RED="$C_RESET"

short_path() {
  local p="$1"
  p="${p/#$HOME/\~}"
  printf '%s' "$p"
}

repeat_char() {
  local char="$1" count="$2" out=""
  while [[ $count -gt 0 ]]; do
    out+="$char"
    ((count--))
  done
  printf '%s' "$out"
}

CACHE_NAMES=("")
CACHE_VALS=("")

write_cache() {
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/what-is-installed"
  mkdir -p "$cache_dir"
  {
    printf 'CACHE_TS=%s\n' "$(date +%s)"
    declare -p CACHE_NAMES 2>/dev/null
    declare -p CACHE_VALS 2>/dev/null
  } > "$cache_dir/versions.cache"
}

load_cache() {
  local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/what-is-installed/versions.cache"
  [[ -f "$cache_file" ]] || return 1
  local now
  now=$(date +%s)
  source "$cache_file" 2>/dev/null || return 1
  [[ -n "${CACHE_TS:-}" && $(( now - CACHE_TS )) -lt 3600 ]] || return 1
}

run_with_timeout() {
  local timeout="${1:-2}" tmpfile pid killer exit_code
  shift
  tmpfile="$(mktemp)"
  "$@" >"$tmpfile" 2>/dev/null &
  pid=$!
  { sleep "$timeout"; kill "$pid" 2>/dev/null; } &
  killer=$!
  wait "$pid" 2>/dev/null
  exit_code=$?
  kill "$killer" 2>/dev/null
  wait "$killer" 2>/dev/null
  if [[ $exit_code -eq 143 || $exit_code -eq 137 ]]; then
    rm -f "$tmpfile"
    return 124
  fi
  cat "$tmpfile"
  rm -f "$tmpfile"
  return $exit_code
}

VERSION_RESULT=""

get_command_version() {
  local cmd="$1" env_prefix output first_line i

  for i in "${!CACHE_NAMES[@]}"; do
    [[ "${CACHE_NAMES[$i]}" == "$cmd" ]] && { VERSION_RESULT="${CACHE_VALS[$i]}"; return; }
  done

  env_prefix="$(get_accel_env "$cmd")"

  if [[ -n "$env_prefix" ]]; then
    output="$(run_with_timeout 1 env $env_prefix "$cmd" --version)" || true
    [[ -z "$output" ]] && output="$(run_with_timeout 1 env $env_prefix "$cmd" -V)" || true
  else
    output="$(run_with_timeout 1 "$cmd" --version)" || true
    [[ -z "$output" ]] && output="$(run_with_timeout 1 "$cmd" -V)" || true
  fi

  local result
  if [[ -z "$output" ]]; then
    result="-"
  else
    if ! printf '%s' "$output" | iconv -f utf-8 -t utf-8 >/dev/null 2>&1; then
      output="$(printf '%s' "$output" | iconv -f latin1 -t utf-8 2>/dev/null || printf '%s' "$output")"
    fi

    first_line="${output%%$'\n'*}"
    if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+)?) ]]; then
      result="${BASH_REMATCH[1]}"
    elif [[ "$first_line" =~ [Vv]ersion[[:space:]]*([0-9]+(\.[0-9]+)*) ]]; then
      result="${BASH_REMATCH[1]}"
    else
      result="-"
    fi
  fi

  CACHE_NAMES+=("$cmd")
  CACHE_VALS+=("$result")
  VERSION_RESULT="$result"
}

[[ -z "$NO_CACHE" ]] && { load_cache || true; }

SEEN_NAMES=("")
SEEN_FAMILIES=("")
SEEN_VERSIONS=("")

ALL_SECTION_DIRS=()
ALL_SECTION_ITEMS=()
ALL_SECTION_COUNTS=()
ALL_SECTION_START=()

SYSTEM_DIRS="$(get_system_dirs)"
FAMILY_SKIP="$(get_family_skip_patterns)"

while IFS= read -r dir; do
  if [[ -z "$INCLUDE_SYSTEM" ]]; then
    [[ "$dir" =~ $SYSTEM_DIRS || -z "$dir" || ! -d "$dir" ]] && continue
  else
    [[ -z "$dir" || ! -d "$dir" ]] && continue
  fi

  label="$(section_label "$dir")"
  section_items_before=${#ALL_SECTION_ITEMS[@]}
  has_items=false

  for path in "$dir"/*; do
    [[ -f "$path" || -L "$path" ]] || continue
    [[ -x "$path" ]] || continue

    name="${path##*/}"

    if [[ -n "${FILTER:-}" ]]; then
      name_lower="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
      filter_lower="$(printf '%s' "$FILTER" | tr '[:upper:]' '[:lower:]')"
      [[ "$name_lower" == *"$filter_lower"* ]] || continue
    fi

    get_command_version "$name"
    ver="$VERSION_RESULT"
    [[ "$ver" == "-" ]] && continue

    found=false
    for seen in "${SEEN_NAMES[@]}"; do
      [[ "$seen" == "$name" ]] && { found=true; break; }
    done
    [[ "$found" == true ]] && continue

    family="${name%-*}"
    [[ "$family" == "$name" ]] && family=""
    if [[ -n "$family" ]]; then
      skip=false
      for j in "${!SEEN_FAMILIES[@]}"; do
        [[ "${SEEN_FAMILIES[$j]}" == "$family" && "${SEEN_VERSIONS[$j]}" == "$ver" ]] && { skip=true; break; }
      done
      [[ "$skip" == true ]] && continue
    fi

    if [[ -n "$FAMILY_SKIP" && "$name" =~ $FAMILY_SKIP ]]; then
      continue
    fi

    case "$name" in
      *-config|*.py) continue ;;
    esac

    SEEN_NAMES+=("$name")
    [[ -n "$family" ]] && { SEEN_FAMILIES+=("$family"); SEEN_VERSIONS+=("$ver"); }

    ALL_SECTION_ITEMS+=("$name|$ver|$path")
    has_items=true
  done

  if [[ "$has_items" == true ]]; then
    count=$(( ${#ALL_SECTION_ITEMS[@]} - section_items_before ))
    ALL_SECTION_DIRS+=("$label")
    ALL_SECTION_START+=("$section_items_before")
    ALL_SECTION_COUNTS+=("$count")
  fi
done < <(printf '%s\n' "$PATH" | tr ':' '\n' | sort -u)

if [[ -n "${SORT_FIELD:-}" && "$SORT_FIELD" != "name" ]]; then
  for si in "${!ALL_SECTION_DIRS[@]}"; do
    start="${ALL_SECTION_START[$si]}"
    count="${ALL_SECTION_COUNTS[$si]}"

    slice=()
    for ((j = start; j < start + count; j++)); do
      slice+=("${ALL_SECTION_ITEMS[$j]}")
    done

    sorted_slice=()
    if [[ "$SORT_FIELD" == "version" ]]; then
      IFS=$'\n' sorted_slice=($(printf '%s\n' "${slice[@]}" | sort -t'|' -k2,2 -V))
    else
      IFS=$'\n' sorted_slice=($(printf '%s\n' "${slice[@]}" | sort -t'|' -k3,3))
    fi

    for ((j = 0; j < count; j++)); do
      ALL_SECTION_ITEMS[$((start + j))]="${sorted_slice[$j]}"
    done
  done
fi

[[ -z "$NO_CACHE" ]] && { write_cache || true; }

dispatch_render
