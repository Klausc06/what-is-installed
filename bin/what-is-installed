#!/usr/bin/env bash
set -euo pipefail

# what-is-installed — 命令行工具扫描器
#
# 扫描 $PATH 中所有目录，展示实际可用的命令及其版本

# ============================================================================
# 参数解析
# ============================================================================

usage() {
  cat <<'EOF'
Usage: what-is-installed [OPTIONS]

Options:
  --help, -h     显示帮助信息
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf '未知参数: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# ============================================================================
# 输出辅助函数
# ============================================================================

print_kvv() {
  printf '%-18s %-14s %s\n' "$1" "$2" "$3"
}

# ============================================================================
# 版本获取
# ============================================================================

VERSION_CACHE_NAMES=()
VERSION_CACHE_VALS=()

get_command_version() {
  local cmd="$1"
  local i

  for i in "${!VERSION_CACHE_NAMES[@]}"; do
    if [[ "${VERSION_CACHE_NAMES[$i]}" == "$cmd" ]]; then
      printf '%s' "${VERSION_CACHE_VALS[$i]}"
      return
    fi
  done

  local version_output="" exit_code=0

  version_output="$("$cmd" --version 2>/dev/null)" || {
    version_output="$("$cmd" -V 2>/dev/null)" || exit_code=$?
  }

  local result="" first_line
  if [[ $exit_code -ne 0 ]] || [[ -z "$version_output" ]]; then
    result="无"
  else
    first_line="${version_output%%$'\n'*}"

    if [[ "$first_line" =~ ([0-9]+\.[0-9]+(\.[0-9]+)?) ]]; then
      result="${BASH_REMATCH[1]}"
    elif [[ "$first_line" =~ [Vv]ersion[[:space:]]*([0-9]+(\.[0-9]+)*) ]]; then
      result="${BASH_REMATCH[1]}"
    else
      result="${first_line:0:30}"
    fi
  fi

  VERSION_CACHE_NAMES+=("$cmd")
  VERSION_CACHE_VALS+=("$result")
  printf '%s' "$result"
}

# ============================================================================
# 输出
# ============================================================================

printf '\n'

# 收集非系统目录 → 分组输出
while IFS= read -r dir; do
  [[ "$dir" == /bin || "$dir" == /sbin || "$dir" == /usr/bin || "$dir" == /usr/sbin || "$dir" == /System/* || "$dir" == /Library/Apple/* ]] && continue
  [[ -z "$dir" || ! -d "$dir" ]] && continue

  # 收集该目录下的命令
  paths="$(find "$dir" -mindepth 1 -maxdepth 1 \( -type f -o -type l \) -perm -111 2>/dev/null | sort -u)"
  [[ -z "$paths" ]] && continue

  # 分类标题
  case "$dir" in
    */.local/bin)        printf '[用户本地]\n' ;;
    */.npm-global/bin)   printf '[npm 全局]\n' ;;
    /opt/homebrew/bin)   printf '[Homebrew]\n' ;;
    */Library/Frameworks/Python.framework/*/bin) printf '[Python 框架]\n' ;;
    */usr/local/bin)     printf '[系统本地]\n' ;;
    */usr/local/sbin)    printf '[系统本地]\n' ;;
    *)                   printf '[其他]\n' ;;
  esac

  # 逐条输出
  while IFS= read -r path; do
    name="$(basename "$path")"
    version_str="$(get_command_version "$name")"
    print_kvv "$name" "$version_str" "$path"
  done <<< "$paths"

  printf '\n'
done < <(printf '%s\n' "$PATH" | tr ':' '\n' | sort -u)
